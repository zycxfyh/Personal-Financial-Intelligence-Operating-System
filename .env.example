PFIOS_ENV=development
PFIOS_DEBUG=true
# Database — PostgreSQL (primary, requires docker compose up -d postgres)
PFIOS_DB_URL=postgresql://pfios:pfios@127.0.0.1:5432/pfios
# Database — DuckDB (analytics / zero-dependency fallback)
# PFIOS_DB_URL=duckdb:///./data/pfios.duckdb
# DuckDB analytics engine (OLAP, backtesting, Parquet/CSV, feature engineering)
# PFIOS_DUCKDB_ANALYTICS_PATH=./data/analytics.duckdb
# Redis (for caching / session / task queue)
# REDIS_URL=redis://127.0.0.1:6379/0
PFIOS_AUDIT_LOG_DIR=./data/logs/audit
PFIOS_REASONING_PROVIDER=mock
PFIOS_HERMES_BASE_URL=http://127.0.0.1:9120/pfios/v1
PFIOS_HERMES_API_TOKEN=
PFIOS_HERMES_TIMEOUT_SECONDS=30
PFIOS_HERMES_MAX_RETRIES=1
PFIOS_HERMES_RETRY_BACKOFF_SECONDS=0.2
PFIOS_HERMES_DEFAULT_MODEL=google/gemini-3.1-pro-preview
PFIOS_HERMES_DEFAULT_PROVIDER=gemini
PFIOS_HERMES_ENABLE_DELEGATION=true
PFIOS_HERMES_ENABLE_MEMORY=true
PFIOS_HERMES_ENABLE_MOA=false
PFIOS_TIMEZONE=Asia/Shanghai
PFIOS_SENTRY_DSN=
PFIOS_OTEL_SERVICE_NAME=aegisos-api
PFIOS_OTEL_EXPORTER_OTLP_ENDPOINT=
